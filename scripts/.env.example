# ========================================================================
# fetch_stocks.py 環境變數範本 (本機測試用)
# GitHub Actions 請改存到 Settings → Secrets and variables → Actions
# ========================================================================

# Service Account 的 JSON 金鑰整份內容 (從 GCP Console 下載那個 .json)
# 注意:整段 JSON 字串用單引號包起來,裡面的雙引號不要動
GOOGLE_CREDENTIALS='{"type":"service_account","project_id":"..."}'

# ────────────────────────────────────────────────────────────────────
# 6 個 Drive 資料夾 ID (對應 GAS CFG.DRIVE)
# 合成一份 JSON 餵給 fetch_stocks.py
# 只列出想備援的 key 即可,未列出的會被跳過
# ────────────────────────────────────────────────────────────────────
DRIVE_FOLDERS='{
  "STOCK_INST_TWSE":  "10_WWPDkJGbUY_Ij6V72VAuUMIa5V9CNC",
  "STOCK_INST_TPEX":  "1w026HJ3DbhiTZ--kh8VMWqkh15yr4IBy",
  "STOCK_PRICE_TWSE": "1MmT3hKTeIUFwXOuAboyPV9-hYKq-sh-s",
  "STOCK_PRICE_TPEX": "1EQnVyObf6XrcJujojHB3v3gspK5IMGxL",
  "CB_PRICE":         "1A7GwMzpz5qaDGjP9cwINvW_YFwvabN-e",
  "CB_INST":          "1oHAQAzK_KHjUIu5iuUBxxKDvg1DbA3Dh"
}'

# 可選:強制抓特定日期 (YYYYMMDD),空白則抓今天 (Asia/Taipei)
# FETCH_DATE=20260424

# 可選:只跑指定來源 (逗號分隔),空白則跑全部 6 個
# SOURCES=STOCK_INST_TWSE,CB_INST

# ========================================================================
# parse_and_export.py 額外環境變數
# (Step 1 開始引入,在此先列好,後續 step 才會真正用到)
# ========================================================================

# Supabase 專案 URL (Settings → API → Project URL)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase service_role key (Settings → API → Project API keys → service_role)
# 注意:這是 server-side 用的 key,會 bypass RLS,絕對不能放進前端
# 真實值寫到 scripts/.env (已被 .gitignore 排除),不要寫到這個檔!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# Telegram Bot token (BotFather → /newbot 產生)
TG_BOT_TOKEN=1234567890:ABC-XXX

# Telegram chat_id (與 bot 對話一次後,訪問:
# https://api.telegram.org/bot<TOKEN>/getUpdates 找 message.chat.id)
TG_CHAT_ID=123456789
